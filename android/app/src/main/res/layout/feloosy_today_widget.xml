<?xml version="1.0" encoding="utf-8"?>
<!-- 3×1 horizontal widget: [account + amount] [bar + legend] [CTA] -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_today_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_today_bg"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:gravity="center_vertical">

    <!-- Left: account label + available amount -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_today_account_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WALLET"
            android:textColor="#7fa890"
            android:textSize="8sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:includeFontPadding="false"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginTop="1dp">

            <TextView
                android:id="@+id/widget_today_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#f6f1e3"
                android:textSize="18sp"
                android:fontFamily="monospace"
                android:includeFontPadding="false"
                android:singleLine="true" />

            <TextView
                android:id="@+id/widget_today_currency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" AED"
                android:textColor="#f5a623"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:includeFontPadding="false"
                android:layout_marginStart="2dp"
                android:layout_marginBottom="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="28dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#20f6f1e3" />

    <!-- Middle: stacked progress bar + legend (fills remaining space) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- Progress bar (bitmap drawn by provider) -->
        <ImageView
            android:id="@+id/widget_today_progress_bar"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:scaleType="fitXY"
            android:adjustViewBounds="false"
            android:contentDescription="Monthly spending bar" />

        <!-- Legend row (normal state) -->
        <LinearLayout
            android:id="@+id/widget_today_legend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/widget_legend_item_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/widget_legend_dot_1"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:scaleType="fitXY" />

                <TextView
                    android:id="@+id/widget_legend_label_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="–"
                    android:textColor="#f6f1e3"
                    android:textSize="9sp"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:ellipsize="end" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_legend_item_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/widget_legend_dot_2"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:scaleType="fitXY" />

                <TextView
                    android:id="@+id/widget_legend_label_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="–"
                    android:textColor="#f6f1e3"
                    android:textSize="9sp"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:ellipsize="end" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_legend_item_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/widget_legend_dot_3"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:scaleType="fitXY" />

                <TextView
                    android:id="@+id/widget_legend_label_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="–"
                    android:textColor="#f6f1e3"
                    android:textSize="9sp"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:ellipsize="end" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_legend_item_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/widget_legend_dot_4"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:scaleType="fitXY" />

                <TextView
                    android:id="@+id/widget_legend_label_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="–"
                    android:textColor="#f6f1e3"
                    android:textSize="9sp"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:ellipsize="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Empty state text -->
        <TextView
            android:id="@+id/widget_today_empty_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="No spending this month"
            android:textColor="#7fa890"
            android:textSize="9sp"
            android:includeFontPadding="false"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Right: add expense CTA -->
    <TextView
        android:id="@+id/widget_today_add_btn"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="12dp"
        android:gravity="center"
        android:text="−"
        android:textColor="#0d2818"
        android:textSize="20sp"
        android:textStyle="bold"
        android:background="@drawable/widget_today_amber_circle"
        android:contentDescription="Add expense" />

</LinearLayout>
